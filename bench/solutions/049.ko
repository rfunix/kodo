module par_sums {
    meta { purpose: "Parallel partial sums", version: "0.1.0" }

    fn main() -> Int {
        let ch: Channel<Int> = channel_new()
        parallel {
            spawn { channel_send(ch, 55) }
            spawn { channel_send(ch, 155) }
            spawn {
                let a: Int = channel_recv(ch)
                let b: Int = channel_recv(ch)
                print_int(a + b)
            }
        }
        return 0
    }
}
