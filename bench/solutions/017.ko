module percentage {
    meta { purpose: "Percentage with range contracts", version: "0.1.0" }

    fn to_percentage(value: Int) -> Int
        requires { value >= 0 }
        requires { value <= 100 }
        ensures { result >= 0 }
        ensures { result <= 100 }
    {
        return value
    }

    fn main() -> Int {
        print_int(to_percentage(75))
        return 0
    }
}
