module abs_demo {
    meta { purpose: "Absolute value with ensures", version: "0.1.0" }

    fn absolute_value(n: Int) -> Int
        ensures { result >= 0 }
    {
        if n < 0 {
            return 0 - n
        }
        return n
    }

    fn main() -> Int {
        print_int(absolute_value(5))
        print_int(absolute_value(-7))
        return 0
    }
}
