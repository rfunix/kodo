module safe_index {
    meta { purpose: "Safe list indexing with contracts", version: "0.1.0" }

    fn safe_get(items: List<Int>, index: Int, size: Int) -> Int
        requires { index >= 0 }
        requires { index < size }
    {
        return list_get(items, index)
    }

    fn main() -> Int {
        let nums: List<Int> = list_new()
        list_push(nums, 10)
        list_push(nums, 20)
        list_push(nums, 30)
        print_int(safe_get(nums, 1, 3))
        return 0
    }
}
