module higher_order_filter {
    meta {
        purpose: "Demonstrate higher-order filter on list",
        version: "0.1.0"
    }

    fn main() -> Int {
        let nums: List<Int> = list_new()
        list_push(nums, 1)
        list_push(nums, 2)
        list_push(nums, 3)
        list_push(nums, 4)
        list_push(nums, 5)

        let evens: List<Int> = nums.filter(|x: Int| -> Bool { x % 2 == 0 })
        print_int(list_length(evens))
        return 0
    }
}
