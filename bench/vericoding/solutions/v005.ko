module vericoding_safe_divide {
    meta {
        purpose: "AlgoVeri v005: safe division precondition prevents zero denominator",
        version: "1.0.0"
    }

    fn safe_div(a: Int, b: Int) -> Int
        requires { b != 0 }
    {
        return a / b
    }

    fn main() -> Int {
        print_int(safe_div(20, 4))
        print_int(safe_div(7, 2))
        return 0
    }
}
