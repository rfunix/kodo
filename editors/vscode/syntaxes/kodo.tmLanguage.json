{
  "name": "Kodo",
  "scopeName": "source.kodo",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#annotations" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.kodo",
          "match": "//.*$"
        },
        {
          "name": "comment.block.kodo",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.kodo",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kodo",
              "match": "\\\\."
            },
            {
              "name": "variable.other.interpolation.kodo",
              "match": "\\$\\{[^}]*\\}"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kodo",
          "match": "\\b(if|else|while|for|in|match|return|break|continue|spawn|parallel|async|await)\\b"
        },
        {
          "name": "keyword.declaration.kodo",
          "match": "\\b(fn|let|mut|ref|own|struct|enum|trait|impl|module|meta|import|from|intent|actor|handler|type)\\b"
        },
        {
          "name": "keyword.contract.kodo",
          "match": "\\b(requires|ensures)\\b"
        },
        {
          "name": "constant.language.kodo",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.kodo",
          "match": "\\b(Int|Int8|Int16|Int32|Int64|Uint|Uint8|Uint16|Uint32|Uint64|Float32|Float64|Bool|String|Byte|Unit)\\b"
        },
        {
          "name": "support.type.generic.kodo",
          "match": "\\b(Option|Result|List|Map)\\b"
        },
        {
          "name": "entity.name.type.kodo",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.kodo",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*(\\([^)]*\\))?"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.kodo",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.kodo",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.kodo",
          "match": "(::|\\.\\?|\\?\\?|\\?|=>|->|==|!=|<=|>=|&&|\\|\\||[+\\-*/%<>=!&|])"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.kodo",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        }
      ]
    }
  }
}
