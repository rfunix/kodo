//@ compile-fail
//@ error-code: E0281
// Note: E0283 (ClosureDoubleCapture) is defined but not emitted by the checker.
// When two closures try to capture the same non-Copy variable, the second closure
// triggers E0281 (ClosureCaptureAfterMove) because the first capture already moved it.
module closure_double_capture {
    meta { purpose: "Two closures both capture same non-Copy variable — second triggers E0281" }

    fn main() -> Int {
        let data: String = "hello"
        // First closure captures data by move (String is non-Copy)
        let _f = |x: Int| -> String { data }
        // Second closure attempts to capture already-moved data — E0281
        let _g = |x: Int| -> String { data }
        return 0
    }
}
