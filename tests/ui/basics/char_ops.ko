//@ check-pass
module char_ops_test {
    meta {
        purpose: "Test character operations and StringBuilder builtins"
        version: "0.1.0"
        author: "test"
    }

    fn main() {
        let s: String = "hello"
        let c: Int = char_at(s, 0)

        let a: Bool = is_alpha(65)
        let d: Bool = is_digit(48)
        let an: Bool = is_alphanumeric(65)
        let ws: Bool = is_whitespace(32)

        let ch: String = char_from_code(65)

        let sb: Int = string_builder_new()
        string_builder_push(sb, "hello")
        string_builder_push_char(sb, 32)
        let result: String = string_builder_to_string(sb)

        let hex: String = format_int(255, 16)

        let ts: Int = timestamp()
        sleep(0)
    }
}
