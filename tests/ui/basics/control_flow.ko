//@ check-pass
module control_flow {
    meta { purpose: "If/else, while, for loops" }

    fn clamp(n: Int) -> Int {
        if n > 100 {
            return 100
        } else {
            if n < 0 {
                return 0
            } else {
                return n
            }
        }
    }

    fn sum_to(n: Int) -> Int {
        let total: Int = 0
        let i: Int = 0
        while i < n {
            total = total + i
            i = i + 1
        }
        return total
    }

    fn main() {
        let x: Int = clamp(150)
        let s: Int = sum_to(10)
    }
}
