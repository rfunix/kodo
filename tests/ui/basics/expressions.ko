//@ check-pass
module expressions {
    meta { purpose: "Expression parsing and type checking" }

    fn arithmetic() -> Int {
        let a: Int = 10
        let b: Int = 3
        let c: Int = a + b * 2 - a / b
        return c
    }

    fn logic(x: Int) -> Bool {
        let positive: Bool = x > 0
        let small: Bool = x < 100
        return positive && small || x == 0
    }

    fn nesting() -> Int {
        let x: Int = (1 + 2) * (3 + 4)
        return -x
    }
}
