//@ run-pass
module custom_error_enum {
    meta { purpose: "Nested enum pattern matching in Result<T, E>" }

    enum AppError {
        NotFound,
        Unauthorized,
        BadRequest(String)
    }

    fn lookup(id: Int) -> Result<String, AppError> {
        if id <= 0 {
            return Result::Err(AppError::BadRequest("bad id"))
        }
        if id == 99 {
            return Result::Err(AppError::Unauthorized)
        }
        if id > 100 {
            return Result::Err(AppError::NotFound)
        }
        return Result::Ok("found")
    }

    fn main() -> Int {
        let r1: Result<String, AppError> = lookup(1)
        match r1 {
            Ok(v) => println(v),
            Err(e) => println("err")
        }

        let r2: Result<String, AppError> = lookup(200)
        match r2 {
            Ok(v) => println(v),
            Err(AppError::NotFound) => println("not found"),
            Err(AppError::Unauthorized) => println("unauthorized"),
            Err(e) => println("other")
        }

        let r3: Result<String, AppError> = lookup(-5)
        match r3 {
            Ok(v) => println(v),
            Err(AppError::BadRequest(msg)) => println(msg),
            Err(e) => println("other")
        }

        return 0
    }
}
