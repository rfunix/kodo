//@ check-pass
module traits_basic {
    meta { purpose: "Basic trait definition and implementation" }

    trait Printable {
        fn to_string(self) -> String
    }

    struct Point {
        x: Int,
        y: Int
    }

    impl Printable for Point {
        fn to_string(self) -> String {
            return "Point"
        }
    }

    fn main() {
        let p: Point = Point { x: 1, y: 2 }
        let s: String = p.to_string()
    }
}
