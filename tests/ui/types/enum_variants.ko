//@ check-pass
module enum_variants {
    meta { purpose: "Enum with data variants" }

    enum Shape {
        Circle(Int),
        Rectangle(Int, Int),
        Point
    }

    fn main() {
        let c: Shape = Shape::Circle(5)
        let a: Int = match c {
            Shape::Circle(r) => r * r * 3,
            Shape::Rectangle(w, h) => w * h,
            Shape::Point => 0
        }
        print_int(a)
    }
}
