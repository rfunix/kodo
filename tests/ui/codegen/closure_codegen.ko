//@ run-pass
module closure_codegen {
    meta { purpose: "Closure capture, call, and higher-order functions through codegen" }

    fn apply(f: (Int) -> Int, x: Int) -> Int {
        return f(x)
    }

    fn make_adder(n: Int) -> (Int) -> Int {
        return |x: Int| -> Int { x + n }
    }

    fn main() -> Int {
        let double: (Int) -> Int = |x: Int| -> Int { x * 2 }
        let add5: (Int) -> Int = make_adder(5)

        let a: Int = apply(double, 10)
        let b: Int = apply(add5, 10)

        print_int(a)
        print_int(b)
        return 0
    }
}
