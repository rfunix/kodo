//@ run-pass
module option_result_codegen {
    meta { purpose: "Option and Result types through full codegen pipeline" }

    enum AppError {
        NotFound,
        InvalidInput
    }

    fn safe_divide(a: Int, b: Int) -> Result<Int, AppError> {
        if b == 0 {
            return Err(AppError::InvalidInput)
        }
        return Ok(a / b)
    }

    fn find_positive(x: Int) -> Option<Int> {
        if x > 0 {
            return Some(x)
        }
        return None
    }

    fn main() -> Int {
        let r1: Result<Int, AppError> = safe_divide(10, 2)
        match r1 {
            Ok(v) => { print_int(v) }
            Err(_) => { print_int(-1) }
        }

        let r2: Result<Int, AppError> = safe_divide(10, 0)
        match r2 {
            Ok(v) => { print_int(v) }
            Err(_) => { print_int(-1) }
        }

        let o1: Option<Int> = find_positive(42)
        match o1 {
            Some(v) => { print_int(v) }
            None => { print_int(0) }
        }

        return 0
    }
}
