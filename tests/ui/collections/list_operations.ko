//@ check-pass
module list_ops {
    meta { purpose: "List collection operations" }

    fn main() {
        let items = list_new()
        list_push(items, 10)
        list_push(items, 20)
        list_push(items, 30)

        let len: Int = list_length(items)
        let first: Int = list_get(items, 0)

        print_int(len)
        print_int(first)
    }
}
