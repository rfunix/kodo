//@ run-pass
// Regression test for issue #56: let binding of Int must copy the value,
// not create an alias. Previously `let tmp = y` was incorrectly propagated
// by copy_propagate, turning the copy into an alias. Fixed by requiring the
// source local to have exactly one definition before propagating.
module int_copy_semantics {
    meta { purpose: "Regression #56: Int let-binding from variable is a value copy" }

    fn main() -> Int {
        let mut y: Int = 8
        let tmp: Int = y
        y = 4
        print_int(tmp)
        print_int(y)
        return 0
    }
}
