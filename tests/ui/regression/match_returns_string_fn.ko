//@ run-fail
// Bug: match expression returning String in a separate function compiles
// but segfaults at runtime (exit 139). The match result_local is allocated
// with Type::Unknown, so codegen does not create a _String stack slot.
// When the String is later used (e.g. passed to print), it reads garbage
// memory instead of the proper (ptr, len) pair.

module match_returns_string_fn {
    meta { purpose: "Regression: match returning String in function causes segfault" }

    enum Direction { North, South }

    fn dir_name(d: Direction) -> String {
        let name: String = match d {
            Direction::North => "north",
            Direction::South => "south"
        }
        return name
    }

    fn main() {
        let d: Direction = Direction::North
        let n: String = dir_name(d)
        print(n)
    }
}
