//@ run-pass
// Fixed: match expression returning String in a separate function now works.
// The fix syncs the resolved type from local_types back into the locals vec
// so codegen allocates the correct _String stack slot (16 bytes for ptr + len).

module match_returns_string_fn {
    meta { purpose: "Regression: match returning String in function causes segfault" }

    enum Direction { North, South }

    fn dir_name(d: Direction) -> String {
        let name: String = match d {
            Direction::North => "north",
            Direction::South => "south"
        }
        return name
    }

    fn main() {
        let d: Direction = Direction::North
        let n: String = dir_name(d)
        print(n)
    }
}
