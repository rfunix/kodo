module generic_fn {
    meta {
        purpose: "Demonstrate generic functions"
        version: "0.1.0"
    }

    fn identity<T>(x: T) -> T {
        return x
    }

    fn main() -> Int {
        let a: Int = identity(42)
        let b: Int = identity(99)
        print_int(a)
        print_int(b)
        return 0
    }
}
