// Real-world example: Agent-Built HTTP Health Checker
//
// Demonstrates Kōdo's file I/O and list operations for
// building real health check tools.
//
// Run with: kodoc build examples/health_checker.ko -o health_checker && ./health_checker

module health_checker {
    meta {
        purpose: "Health checker demonstrating file I/O and list operations"
        version: "1.0.0"
        author: "claude"
    }

    fn main() -> Int {
        println("=== Health Check Report ===")

        // Check if key files exist
        let results: List<Int> = list_new()

        let e1: Bool = file_exists("Cargo.toml")
        if e1 {
            println("  [OK] Cargo.toml")
            list_push(results, 1)
        } else {
            println("  [FAIL] Cargo.toml")
            list_push(results, 0)
        }

        let e2: Bool = file_exists("examples/hello.ko")
        if e2 {
            println("  [OK] examples/hello.ko")
            list_push(results, 1)
        } else {
            println("  [FAIL] examples/hello.ko")
            list_push(results, 0)
        }

        let e3: Bool = file_exists("nonexistent.txt")
        if e3 {
            println("  [FAIL] nonexistent.txt should not exist")
            list_push(results, 0)
        } else {
            println("  [OK] nonexistent.txt correctly missing")
            list_push(results, 1)
        }

        // Summary
        let total: Int = list_length(results)
        let healthy_count: Int = results.fold(0, |acc: Int, x: Int| -> Int { acc + x })
        println("Checks passed:")
        print_int(healthy_count)
        println("Total checks:")
        print_int(total)

        if healthy_count == total {
            println("All systems operational.")
        } else {
            println("WARNING: some checks failed!")
        }

        return 0
    }
}
