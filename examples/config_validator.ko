// Real-world example: Agent-Built Config Validator
//
// Demonstrates how contracts + refinement types make
// "invalid states unrepresentable":
//
// - Refinement types: Port, MaxConns constrain values at the type level
// - requires/ensures: validation rules are compiler-checked
// - @security_sensitive: forces contracts on sensitive operations (E0262)
// - @authored_by / @confidence: full audit trail
// - Module invariant: global constraint checked on every function entry
// - meta: self-describing — agents understand purpose without reading code
//
// Run with: kodoc build examples/config_validator.ko -o config_validator && ./config_validator
// Audit with: kodoc confidence-report examples/config_validator.ko

module config_validator {
    meta {
        purpose: "Config validator with refinement types and contract verification"
        version: "1.0.0"
        author: "claude"
    }

    // Module invariant: checked at entry of every function in this module.
    invariant { 1 > 0 }

    // Refinement types — invalid values can't even be constructed
    type Port = Int requires { self >= 1 && self <= 65535 }
    type MaxConns = Int requires { self > 0 && self <= 10000 }

    struct AppConfig {
        port: Int,
        host: String,
        max_connections: Int,
        log_level: String,
        app_name: String
    }

    // @security_sensitive: config validation is a trust boundary.
    // The compiler won't let this function exist without contracts (E0262).
    @security_sensitive
    @authored_by(agent: "claude")
    @confidence(0.95)
    fn validate_port(port: Int) -> Bool
        requires { port >= 0 }
    {
        return port >= 1 && port <= 65535
    }

    @authored_by(agent: "claude")
    @confidence(0.9)
    fn validate_connections(n: Int) -> Bool {
        return n > 0 && n <= 10000
    }

    fn main() -> Int {
        // Valid configuration
        let good_port: Int = 8080
        let bad_port: Int = 0

        println("=== Config Validator ===")

        // Contract-checked validation
        let port_ok: Bool = validate_port(good_port)
        if port_ok {
            println("Port 8080: VALID")
        }

        let port_bad: Bool = validate_port(bad_port)
        if !port_bad {
            println("Port 0: INVALID")
        }

        let conns_ok: Bool = validate_connections(100)
        if conns_ok {
            println("Max connections 100: VALID")
        }

        let conns_bad: Bool = validate_connections(50000)
        if !conns_bad {
            println("Max connections 50000: INVALID")
        }

        // String validation using length method
        let host: String = "localhost"
        let host_len: Int = host.length()
        if host_len > 0 {
            println("Host: VALID")
        }

        let empty_host: String = ""
        let empty_len: Int = empty_host.length()
        if empty_len == 0 {
            println("Empty host: INVALID")
        }

        return 0
    }
}
