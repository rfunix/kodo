// Real-world example: Agent-Built URL Shortener
//
// Demonstrates how contracts make agent-generated code
// "correct by construction":
//
// - requires/ensures: every function documents its expectations
// - @authored_by / @confidence: audit trail for every function
// - @security_sensitive: validation code MUST have contracts (E0262)
// - Refinement types: ShortCode constrains values at the type level
// - meta: self-describing module — agents know what this module does
//
// Run with: kodoc build examples/url_shortener.ko -o url_shortener && ./url_shortener
// Audit with: kodoc confidence-report examples/url_shortener.ko

module url_shortener {
    meta {
        purpose: "URL shortener with contract-verified validation"
        version: "1.0.0"
        author: "claude"
    }

    // Refinement type: codes must be positive
    type ShortCode = Int requires { self > 0 }

    // Contract: code must be positive. The compiler verifies every call site.
    @authored_by(agent: "claude")
    @confidence(0.95)
    fn register_url(tracker: Map<Int, Int>, code: Int)
        requires { code > 0 }
    {
        map_insert(tracker, code, 0)
    }

    // Contract chain: record_visit also requires code > 0.
    // Agent can't accidentally call with code=0 — the compiler catches it.
    @authored_by(agent: "claude")
    @confidence(0.9)
    fn record_visit(tracker: Map<Int, Int>, code: Int)
        requires { code > 0 }
    {
        let current: Int = map_get(tracker, code)
        map_insert(tracker, code, current + 1)
    }

    @authored_by(agent: "claude")
    @confidence(0.9)
    fn get_visits(tracker: Map<Int, Int>, code: Int) -> Int
        requires { code > 0 }
    {
        return map_get(tracker, code)
    }

    fn main() -> Int {
        let tracker: Map<Int, Int> = map_new()

        println("=== URL Shortener ===")

        // Validate URLs using string methods
        let url1: String = "https://kodo-lang.dev/docs"
        let valid1: Bool = url1.starts_with("https://")
        if valid1 {
            register_url(tracker, 1)
            println("Registered code 1")
        }

        let url2: String = "ftp://invalid.example.com"
        let valid2: Bool = url2.starts_with("http://")
        let valid2b: Bool = url2.starts_with("https://")
        if valid2 || valid2b {
            register_url(tracker, 2)
        } else {
            println("Rejected invalid URL")
        }

        // Track visits — contracts enforce code > 0
        record_visit(tracker, 1)
        record_visit(tracker, 1)
        record_visit(tracker, 1)

        let visits: Int = get_visits(tracker, 1)
        println("Code 1 visits:")
        print_int(visits)

        if !map_contains_key(tracker, 99) {
            println("Code 99: NOT FOUND")
        }

        return 0
    }
}
