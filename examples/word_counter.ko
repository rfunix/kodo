// Real-world example: Agent-Built Word Counter
//
// Demonstrates Kōdo's string and list operations for text processing.
//
// Run with: kodoc build examples/word_counter.ko -o word_counter && ./word_counter

module word_counter {
    meta {
        purpose: "Word counter demonstrating text processing"
        version: "1.0.0"
        author: "claude"
    }

    fn main() -> Int {
        // String length
        let char_count: Int = String_length("The quick brown fox jumps over the lazy dog")

        // Check containment
        let has_fox: Bool = String_contains("The quick brown fox", "fox")

        println("=== Word Counter ===")
        println("Chars:")
        print_int(char_count)

        if has_fox {
            println("Contains fox: yes")
        }

        // Aggregate counts using list operations
        let counts: List<Int> = list_new()
        list_push(counts, char_count)
        list_push(counts, 7)
        let total: Int = list_length(counts)
        println("Samples:")
        print_int(total)

        return 0
    }
}
