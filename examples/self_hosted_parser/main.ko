        let s3: String = "module cond { meta { purpose: \"cond\" version: \"1.0\" } fn max(a: Int, b: Int) -> Int { if a > b { return a } else { return b } } fn main() -> Int { return max(10, 20) } }"
        let r3: Bool = run_test("Test 3: If/else", s3)
        if r3 { pass = pass + 1 } else { fail = fail + 1 }

        // Test 4: While loop with mutation
        let s4: String = "module loops { meta { purpose: \"loops\" version: \"1.0\" } fn main() -> Int { let mut i: Int = 0 let mut sum: Int = 0 while i < 10 { sum = sum + i i = i + 1 } return sum } }"
        let r4: Bool = run_test("Test 4: While loop", s4)
        if r4 { pass = pass + 1 } else { fail = fail + 1 }

        // Test 5: Struct
        let s5: String = "module types { meta { purpose: \"types\" version: \"1.0\" } struct Point { x: Int, y: Int } fn main() -> Int { return 0 } }"
        let r5: Bool = run_test("Test 5: Struct", s5)
        if r5 { pass = pass + 1 } else { fail = fail + 1 }

