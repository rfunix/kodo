module math_tests {
    meta {
        purpose: "Tests for math operations"
        version: "0.1.0"
    }

    fn add(a: Int, b: Int) -> Int {
        return a + b
    }

    fn sub(a: Int, b: Int) -> Int {
        return a - b
    }

    test "addition of positive integers" {
        assert_eq(add(2, 3), 5)
        assert_eq(add(0, 0), 0)
    }

    test "addition of negative integers" {
        assert_eq(add(-1, -2), -3)
    }

    test "subtraction" {
        assert_eq(sub(10, 3), 7)
        assert_eq(sub(0, 5), -5)
    }

    test "boolean assertions" {
        assert(true)
        assert_true(2 > 1)
        assert_false(1 > 2)
    }

    test "string equality" {
        let a: String = "hello"
        let b: String = "hello"
        assert_eq(a, b)
        assert_ne(a, "world")
    }

    test "integer inequality" {
        assert_ne(1, 2)
        assert_ne(0, -1)
    }
}
